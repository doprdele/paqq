{
  "name": "packt",
  "version": "0.0.1",
  "description": "Packt backend using cf workers.",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "wrangler dev",
    "start:worker": "wrangler dev",
    "start:node": "tsx src/node.ts",
    "deploy": "wrangler publish",
    "test": "vitest run",
    "test:integration": "vitest run test/usps.integration.test.ts test/uniuni.integration.test.ts",
    "test:live:uniuni": "RUN_LIVE_UNIUNI_BACKEND_TESTS=1 vitest run test/live.uniuni.integration.test.ts"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^1.0.0",
    "ajv": "^8.17.1",
    "typescript": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
