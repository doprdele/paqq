{
  "name": "paqq-backend",
  "version": "2026.3.4",
  "description": "Paqq backend API and scheduler.",
  "main": "dist/node.js",
  "scripts": {
    "build": "bunx --bun tsc",
    "start": "bun run start:node",
    "start:node": "bun src/node.ts",
    "test": "bunx --bun vitest run",
    "test:integration": "bunx --bun vitest run test/usps.integration.test.ts test/uniuni.integration.test.ts test/ups.integration.test.ts test/amazon.import.integration.test.ts",
    "test:live:uniuni": "RUN_LIVE_UNIUNI_BACKEND_TESTS=1 bunx --bun vitest run test/live.uniuni.integration.test.ts",
    "test:live:ups": "RUN_LIVE_UPS_BACKEND_TESTS=1 bunx --bun vitest run test/live.ups.integration.test.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "typescript": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "vitest": "^3.2.4"
  }
}
